    "start": "node dist/index.js",
    "format": "biome format --write"
  },
  "dependencies": {
    "@openai/agents": "^0.11.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
