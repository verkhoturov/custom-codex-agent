{
  "name": "custom-codex-agent",
  "version": "1.0.0",
  "description": "Interactive coding agent powered by the OpenAI Agents SDK and Codex CLI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verkhoturov/custom-codex-agent.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "custom-codex-agent": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit && biome check",
